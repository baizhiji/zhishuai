// Prisma Schema for 智枢AI SaaS System

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  phone         String    @unique
  password      String
  name          String?
  avatar        String?
  role          String    @default("user") // admin, agent, user
  status        String    @default("active") // active, inactive
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // 关联数据
  recruitmentPosts    RecruitmentPost[]
  candidates          Candidate[]
  acquisitionTasks    AcquisitionTask[]
  acquisitionLeads    AcquisitionLead[]
  shareRecords        ShareRecord[]
  shareQrCodes        ShareQrCode[]
  materials           Material[]
  matrixAccounts       MatrixAccount[]
  publishedContents    PublishedContent[]
  notifications       Notification[]
  crmCustomers        CrmCustomer[]
  recruitmentResumes  RecruitmentResume[]
  
  // 功能开关关联
  featureSwitches    UserFeatureSwitch[]
  
  // 代理商关联
  agent              Agent?
  agentRelation      UserAgentRelation?
  
  // 贴牌配置关联
  brandingConfig     BrandingConfig?
  
  // 操作日志
  adminLogs          AdminLog[]
}

model RecruitmentPost {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  salaryMin   Int?
  salaryMax   Int?
  education   String?   // 初中及以下, 高中, 大专, 本科, 硕士, 博士
  experience  String?   // 不限, 1年以下, 1-3年, 3-5年, 5-10年, 10年以上
  jobType     String?   // 全职, 兼职, 实习, 合同工
  description String?
  requirements String?
  benefits    String?
  status      String    @default("recruiting") // recruiting, paused, closed
  candidateCount Int    @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  candidates  Candidate[]
}

model Candidate {
  id          String    @id @default(uuid())
  postId      String
  post        RecruitmentPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  resume      String?   // 简历URL
  education   String?
  experience  String?
  status      String    @default("pending") // pending, contacted, interview, hired, rejected
  remark      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AcquisitionTask {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  channel     String    // douyin, wechat, xiaohongshu, sms
  status      String    @default("pending") // pending, running, completed, paused
  progress    Int       @default(0)
  leadsCount  Int       @default(0)
  targetCount Int?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  leads       AcquisitionLead[]
}

model AcquisitionLead {
  id          String    @id @default(uuid())
  taskId      String
  task        AcquisitionTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String?
  phone       String
  source      String?   // douyin, wechat, xiaohongshu, sms, scan_qr
  status      String    @default("new") // new, contacted, converted, invalid
  convertedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ShareRecord {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrCodeId    String?
  qrCode      ShareQrCode? @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)
  platform    String    // douyin, kuaishou, xiaohongshu, videoname
  scannerId   String?   // 扫码用户ID
  status      String    @default("scanned") // scanned, published, converted
  scannedAt   DateTime  @default(now())
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ShareQrCode {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  videoUrl    String?
  videoCover  String?
  platforms   String    // 逗号分隔: douyin,kuaishou,xiaohongshu,videoname
  qrCodeUrl   String?
  scanCount   Int       @default(0)
  publishCount Int       @default(0)
  activeCount Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  shareRecords ShareRecord[]
}

model Material {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String    // title, topic, copywriter, image, video, audio
  title       String?
  content     String?
  fileUrl     String?
  fileType    String?   // pdf, doc, jpg, png, mp4, mp3
  thumbnail   String?
  status      String    @default("unused") // unused, used
  usedCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model MatrixAccount {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform    String    // douyin, kuaishou, xiaohongshu, videoname, wechat
  accountId   String    // 平台账号ID
  accountName String
  avatar      String?
  status      String    @default("active") // active, inactive, expired
  autoPublish Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  publishedContents PublishedContent[]
}

model PublishedContent {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  matrixAccountId String?
  matrixAccount MatrixAccount? @relation(fields: [matrixAccountId], references: [id], onDelete: SetNull)
  title       String
  content     String?
  mediaUrls   String?   // JSON数组
  platform    String
  accountName String?
  status      String    @default("published") // pending, published, failed
  views       Int       @default(0)
  likes       Int       @default(0)
  comments    Int       @default(0)
  shares      Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Notification {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String    // system, order, activity
  title       String
  content     String
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

model CrmCustomer {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  phone       String?
  wechat      String?
  company     String?
  position    String?
  source      String?
  level       String?   // A, B, C, D
  status      String    @default("potential") // potential, active, inactive
  remark      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model CompanyInfo {
  id          String    @id @default(uuid())
  userId      String    @unique
  name        String    @default("上海百智集网络科技有限公司")
  logo        String?
  industry    String?
  size        String?
  address     String?
  description String?
  contact     String?
  phone       String?
  email       String?
  website     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Setting {
  id          String    @id @default(uuid())
  userId      String
  key         String
  value       String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, key])
}

model RecruitmentResume {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId       String
  name        String
  phone       String
  email       String?
  resumeUrl   String?
  coverLetter String?
  status      String    @default("pending")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============================================
// 功能开关系统
// ============================================

// 功能开关定义表（系统级）
model FeatureSwitch {
  id          String    @id @default(uuid())
  code        String    @unique  // 功能代码：media, recruitment, acquisition, share, referral
  name        String              // 功能名称：自媒体运营, 招聘助手, 智能获客, 推荐分享, 转介绍
  description String?             // 功能描述
  icon        String?             // 图标
  enabled     Boolean   @default(true)  // 默认开启
  sortOrder   Int       @default(0)     // 排序
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  // 子功能开关
  subFeatures FeatureSubSwitch[]
}

// 子功能开关定义表
model FeatureSubSwitch {
  id          String    @id @default(uuid())
  featureCode String              // 关联功能代码
  code        String              // 子功能代码
  name        String              // 子功能名称
  description String?             // 描述
  enabled     Boolean   @default(true)  // 默认开启
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  feature     FeatureSwitch @relation(fields: [featureCode], references: [code])
  
  @@unique([featureCode, code])
}

// 用户功能开关表（租户级覆盖）
model UserFeatureSwitch {
  id          String    @id @default(uuid())
  userId      String              // 用户ID
  featureCode String              // 功能代码
  enabled     Boolean             // 是否开启
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@unique([userId, featureCode])
}

// 代理商表
model Agent {
  id            String    @id @default(uuid())
  userId        String    @unique  // 关联的用户ID
  name          String              // 代理商名称
  level         String    @default("district")  // 级别: country, province, city, district
  region        String?             // 区域
  commissionRate Decimal   @default(0.3)  // 分成比例
  status        String    @default("active")  // active, frozen
  balance       Decimal   @default(0)  // 账户余额
  totalRevenue  Decimal   @default(0)  // 累计收益
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // 关联的用户
  user          User      @relation(fields: [userId], references: [id])
  
  // 下级代理
  parentId      String?
  parent        Agent?    @relation("AgentHierarchy", fields: [parentId], references: [id])
  children      Agent[]   @relation("AgentHierarchy")
  
  // 关联客户
  customers     User[]    @relation("AgentCustomers")
}

// 用户与代理商关联表
model UserAgentRelation {
  id          String    @id @default(uuid())
  userId      String
  agentId     String
  createdAt   DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id])
  agent       Agent     @relation(fields: [agentId], references: [id])
  
  @@unique([userId])
}

// 贴牌配置表
model BrandingConfig {
  id          String    @id @default(uuid())
  userId      String    @unique  // 租户用户ID
  appName     String    @default("智枢AI")  // APP名称
  logo        String?             // LOGO URL
  favicon     String?             // favicon
  themeColor  String    @default("#1890ff")  // 主题色
  primaryColor String    @default("#1890ff")  // 主色
  secondaryColor String  @default("#52c41a")  // 次色
  welcomeText String?             // 欢迎语
  description String?             // 描述
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// 代理商业绩统计表
model AgentStats {
  id          String    @id @default(uuid())
  agentId     String
  period      String              // 统计周期: daily, weekly, monthly
  periodStart DateTime            // 周期开始时间
  periodEnd   DateTime            // 周期结束时间
  newCustomers Int       @default(0)  // 新增客户
  activeCustomers Int   @default(0)  // 活跃客户
  totalRevenue Decimal   @default(0)  // 收益
  commission  Decimal   @default(0)  // 佣金
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@unique([agentId, period, periodStart])
}

// 操作日志表
model AdminLog {
  id          String    @id @default(uuid())
  userId      String              // 操作人ID
  userName    String?             // 操作人名称
  action      String              // 操作类型
  target      String?             // 操作对象
  detail      String?             // 详情
  ip          String?             // IP地址
  userAgent   String?             // 浏览器UA
  createdAt   DateTime  @default(now())
}

// API服务商表
model ApiProvider {
  id          String    @id @default(uuid())
  name        String    @unique           // 服务商名称
  type        String    @default("coze")  // coze, volcengine, openai, custom
  baseUrl     String                     // API地址
  apiKey      String                     // API密钥（加密存储）
  enabled     Boolean   @default(true)    // 是否启用
  isDefault   Boolean   @default(false)  // 是否默认
  priority    Int      @default(0)        // 优先级（数字越小优先级越高）
  config      Json?                      // 其他配置（模型列表等）
  remark      String?                    // 备注
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// 代理商API配置表（覆盖系统默认配置）
model AgentApiConfig {
  id          String    @id @default(uuid())
  agentId     String    @unique           // 代理商ID（关联User）
  providerId  String                     // 指定的API服务商ID
  apiKey      String                     // 代理商自己的API密钥
  enabled     Boolean   @default(true)    // 是否启用
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([agentId])
}

// API使用日志表
model ApiUsageLog {
  id          String    @id @default(uuid())
  userId      String                     // 用户ID
  agentId     String?                    // 代理商ID
  providerId  String                     // 使用的服务商ID
  providerName String                    // 服务商名称
  endpoint    String                     // 调用的端点
  model       String?                    // 使用的模型
  requestTokens Int?                    // 请求Token数
  responseTokens Int?                   // 响应Token数
  cost        Decimal?   @default(0)     // 费用
  duration    Int?                       // 耗时(ms)
  status      String    @default("success") // success, failed
  errorMsg    String?                    // 错误信息
  createdAt   DateTime  @default(now())
  
  @@index([userId, createdAt])
  @@index([agentId, createdAt])
}

// 短信发送记录表
model SmsLog {
  id          String    @id @default(uuid())
  phone       String                     // 手机号
  type        String                     // 类型: register, login, forgot_password, verify
  code        String                     // 验证码
  expiresAt   DateTime                   // 过期时间
  used        Boolean   @default(false)  // 是否已使用
  usedAt      DateTime?                  // 使用时间
  ip          String?                    // 请求IP
  userId      String?                    // 用户ID（登录/注册后）
  status      String    @default("pending") // pending, sent, verified, expired, failed
  errorMsg    String?                    // 错误信息
  provider    String    @default("aliyun") // 短信服务商: aliyun, tencent
  createdAt   DateTime  @default(now())
  
  @@index([phone, createdAt])
  @@index([code, type])
}

// 短信配置表
model SmsConfig {
  id          String    @id @default(uuid())
  provider    String    @unique           // 服务商: aliyun, tencent
  accessKeyId String                     // 访问密钥ID（加密存储）
  accessKeySecret String                  // 访问密钥密钥（加密存储）
  signName    String                     // 签名名称
  templateCode String                    // 模板CODE
  enabled     Boolean   @default(true)    // 是否启用
  isDefault   Boolean   @default(false)  // 是否默认
  config      Json?                      // 其他配置
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
