// Prisma Schema for 智枢AI SaaS System
// 合并版本 - 包含所有功能模型

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户系统
// ============================================

model User {
  id            String    @id @default(uuid())
  phone         String    @unique
  password      String
  name          String?
  email         String?
  company       String?
  avatar        String?
  role          String    @default("user") // admin, agent, user
  status        String    @default("active") // active, inactive
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // 客户计费相关（仅租户客户使用）
  fee           Decimal   @default(0) @db.Decimal(10,2)    // 收费金额
  totalPaid     Decimal   @default(0) @db.Decimal(10,2)   // 累计已付金额
  monthlyPaid   Decimal   @default(0) @db.Decimal(10,2)   // 当月已付金额（每月初重置）
  lastPaidAt    DateTime?              // 最后支付时间
  expireAt      DateTime?              // 服务到期时间
  
  // 推送通知
  pushToken     String?               // FCM/APNs设备推送Token
  pushPlatform  String?               // apns | fcm | web
  pushTokenUpdatedAt DateTime?        // Token最后更新时间
  
  // 关联数据
  recruitmentPosts    RecruitmentPost[]
  candidates          Candidate[]
  acquisitionTasks    AcquisitionTask[]
  acquisitionLeads    AcquisitionLead[]
  leadFollowups       LeadFollowup[]
  acquisitionAutomations AcquisitionAutomation[]
  shareRecords        ShareRecord[]
  shareQrCodes        ShareQrCode[]
  materials           Material[]
  matrixAccounts       MatrixAccount[]
  publishedContents    PublishedContent[]
  notifications       Notification[]
  crmCustomers        CrmCustomer[]
  crmTags             CrmTag[]
  crmAutomationRules  CrmAutomationRule[]
  crmReminders        CrmReminder[]
  recruitmentResumes  RecruitmentResume[]
  featureSwitches    UserFeatureSwitch[]
  mapFavorites       MapFavorite[]
  liveRooms          LiveRoom[]
  orders             Order[]
  scheduledTasks     ScheduledTask[]
  agent              Agent?
  agentRelation      UserAgentRelation?
  brandingConfig     BrandingConfig?
  adminLogs          AdminLog[]
  employees          Employee[]
  scriptTemplates    ScriptTemplate[]
  acquisitionSources  AcquisitionSource[]
  acquisitionData     AcquisitionData[]
  dataCollectionTasks DataCollectionTask[]
  conversationLogs   ConversationLog[]
  digitalHumans      DigitalHuman[]
  voiceClones        VoiceClone[]
  videoClones        VideoClone[]
  videoTasks         VideoTask[]
  payments           Payment[]
  publishRecords     PublishRecord[]
  recruitmentCommunications RecruitmentCommunication[]
  interviews         Interview[]
  candidateSearchConfigs CandidateSearchConfig[]
  userSettings          UserSettings?
  socialAccounts        SocialAccount[]
}

// ============================================
// 招聘系统
// ============================================

model RecruitmentPost {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  salaryMin   Int?
  salaryMax   Int?
  education   String?
  experience  String?
  jobType     String?
  description String?
  requirements String?
  benefits    String?
  status      String    @default("recruiting")
  candidateCount Int    @default(0)
  recruiterName String?
  recruiterPhone String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  candidates  Candidate[]
  resumes     RecruitmentResume[]
  processes   RecruitmentProcess[]
  communications RecruitmentCommunication[]
  interviews     Interview[]
  searchConfigs  CandidateSearchConfig[]
}

model Candidate {
  id          String    @id @default(uuid())
  postId      String
  post        RecruitmentPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  email       String?
  resume      String?
  education   String?
  experience  String?
  skills      String?   // JSON数组
  source      String?   @default("manual")  // manual/boss/lagou/zhipin/51job/referral
  matchScore  Int?      @default(0)  // AI匹配评分 0-100
  location    String?
  status      String    @default("pending")  // pending/contacted/communicating/interviewed/offered/hired/rejected
  remark      String?
  lastContactedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  communications RecruitmentCommunication[]
  interviews     Interview[]
}

model RecruitmentResume {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId       String
  job         RecruitmentPost @relation(fields: [jobId], references: [id], onDelete: Cascade)
  name        String
  phone       String
  email       String?
  education   String?
  experience  String?
  resumeUrl   String?
  coverLetter String?
  status      String    @default("pending")
  notes       String?
  aiScore     Int?
  aiAnalysis  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  processes   RecruitmentProcess[]
  
  @@index([userId, status])
  @@index([jobId])
  @@index([createdAt])
}

model RecruitmentProcess {
  id            String    @id @default(uuid())
  userId        String
  resumeId      String
  jobId         String
  stage         String    @default("screening")
  notes         String?
  scheduledAt   DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  resume        RecruitmentResume @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  job           RecruitmentPost   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  @@index([userId, stage])
  @@index([resumeId])
  @@index([jobId])
}

// 招聘沟通记录
model RecruitmentCommunication {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidateId   String
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  postId        String?
  post          RecruitmentPost? @relation(fields: [postId], references: [id], onDelete: SetNull)
  channel       String    @default("platform")  // platform/phone/email/wechat
  direction     String    @default("outbound")  // outbound(主动联系)/inbound(候选人回复)
  content       String
  aiGenerated   Boolean   @default(false)
  readByCandidate Boolean @default(false)
  createdAt     DateTime  @default(now())

  @@index([userId, candidateId])
  @@index([postId])
  @@index([createdAt])
}

// 面试安排
model Interview {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  candidateId   String
  candidate     Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  postId        String
  post          RecruitmentPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  round         Int       @default(1)  // 面试轮次
  type          String    @default("video")  // video/phone/onsite
  scheduledAt   DateTime
  duration      Int       @default(60)  // 分钟
  location      String?   // 面试地点或会议链接
  interviewer   String?   // 面试官
  status        String    @default("scheduled")  // scheduled/confirmed/completed/cancelled/no_show
  feedback      String?   // 面试反馈
  score         Int?      // 面试评分 1-100
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, status])
  @@index([candidateId])
  @@index([postId])
  @@index([scheduledAt])
}

// 候选人搜索配置
model CandidateSearchConfig {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId        String
  post          RecruitmentPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  platform      String    @default("boss")  // boss/lagou/zhipin/51job
  keywords      String?   // 搜索关键词 JSON数组
  location      String?
  experienceMin Int?
  experienceMax Int?
  education     String?
  salaryMin     Int?
  salaryMax     Int?
  skills        String?   // 技能要求 JSON数组
  autoContact   Boolean   @default(false)  // 是否自动联系匹配候选人
  contactTemplate String? // 联系话术模板
  status        String    @default("active")  // active/paused/completed
  lastSearchedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, postId])
  @@index([platform, status])
}

// ============================================
// 获客系统
// ============================================

model AcquisitionTask {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  channel     String
  status      String    @default("pending")
  progress    Int       @default(0)
  leadsCount  Int       @default(0)
  targetCount Int?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  leads       AcquisitionLead[]
}

model AcquisitionLead {
  id          String    @id @default(uuid())
  taskId      String?
  task        AcquisitionTask? @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String?
  phone       String
  email       String?
  source      String?
  status      String    @default("new")
  convertedAt DateTime?
  aiScore     Int?
  aiQuality   String?
  aiInsights  String?
  aiFollowup  String?
  notes       String?
  lastContact DateTime?
  followups   LeadFollowup[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([userId, status])
  @@index([source])
  @@index([aiScore])
}

model LeadFollowup {
  id          String    @id @default(uuid())
  leadId      String
  lead        AcquisitionLead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String    @default("note")
  content     String
  nextDate    DateTime?
  createdAt   DateTime  @default(now())
  
  @@index([leadId])
}

model AcquisitionAutomation {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  platform        String
  status          String    @default("draft")
  targetLeads     Int       @default(100)
  currentLeads    Int       @default(0)
  productInfo     String?
  targetAudience  String?
  strategy        Json?
  schedule        DateTime?
  startedAt       DateTime?
  completedAt     DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([userId, status])
}

model AcquisitionSource {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  type        String
  config      Json?
  enabled     Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@unique([userId, type])
}

model AcquisitionData {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  source      String
  sourceType  String
  name        String?
  phone       String?
  email       String?
  wechat      String?
  company     String?
  position    String?
  address     String?
  latitude    Float?
  longitude   Float?
  business    String?
  employeeCount String?
  roomId      String?
  roomName    String?
  platform    String?
  intentScore Int?
  intentLevel String?
  intentTags  String?
  status      String    @default("new")
  followupAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([userId, source])
  @@index([userId, status])
  @@index([intentScore])
}

model DataCollectionTask {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  source      String
  keywords    String?
  industry    String?
  region      String?
  radius      Int?
  centerLat   Float?
  centerLng   Float?
  status      String    @default("pending")
  totalCount  Int       @default(0)
  collectedCount Int    @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([userId, status])
}

// ============================================
// 分享与推荐
// ============================================

model ShareRecord {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrCodeId    String?
  qrCode      ShareQrCode? @relation(fields: [qrCodeId], references: [id], onDelete: SetNull)
  platform    String
  scannerId   String?
  status      String    @default("scanned")
  scannedAt   DateTime  @default(now())
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ShareQrCode {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  videoUrl    String?
  videoCover  String?
  platforms   String
  qrCodeUrl   String?
  scanCount   Int       @default(0)
  publishCount Int      @default(0)
  activeCount Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  shareRecords ShareRecord[]
}

// ============================================
// 素材库与发布
// ============================================

model Material {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String    // title, topic, copywriter, image, video, audio
  title       String?
  content     String?
  fileUrl     String?
  fileType    String?
  thumbnail   String?
  status      String    @default("unused") // unused, used, pending, publishing, published, failed, scheduled
  usedCount   Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // 素材去重与使用追踪
  contentHash   String?  // 文本内容 SHA256 哈希（精确匹配）
  fileHash      String?  // 文件 SHA256 哈希（精确匹配）
  simHash       String?  // SimHash 指纹（模糊匹配）
  usagePlatforms String? // 已使用平台列表 JSON，如 ["douyin","kuaishou"]
  isDuplicate   Boolean  @default(false) // 是否被标记为重复素材

  publishRecords PublishRecord[]

  @@index([userId, type])
  @@index([contentHash])
  @@index([fileHash])
  @@index([simHash])
  @@index([userId, isDuplicate])
}

model PublishRecord {
  id            String    @id @default(uuid())
  materialId    String
  material      Material  @relation(fields: [materialId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId     String
  socialAccount SocialAccount? @relation(fields: [accountId], references: [id])
  platform      String
  status        String    @default("pending")
  publishedUrl  String?
  publishedId   String?
  error         String?
  scheduledAt   DateTime?
  publishedAt   DateTime?
  views         Int       @default(0)
  likes         Int       @default(0)
  comments      Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([materialId])
  @@index([userId])
  @@index([status])
}

// ============================================
// 矩阵账号与发布
// ============================================

model MatrixAccount {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform    String
  accountId   String
  accountName String
  avatar      String?
  status      String    @default("active")
  autoPublish Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  publishedContents PublishedContent[]
}

model PublishedContent {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  matrixAccountId String?
  matrixAccount MatrixAccount? @relation(fields: [matrixAccountId], references: [id], onDelete: SetNull)
  title       String
  content     String?
  mediaUrls   String?
  platform    String
  accountName String?
  status      String    @default("published")
  views       Int       @default(0)
  likes       Int       @default(0)
  comments    Int       @default(0)
  shares      Int       @default(0)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ScheduledTask {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title         String
  content       String
  images        String?   // JSON格式
  platform      String
  accountId     String
  scheduledTime DateTime
  status        String    @default("pending")
  result        String?
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  @@index([userId])
  @@index([status])
  @@index([scheduledTime])
}

// ============================================
// CRM 系统
// ============================================

model CrmCustomer {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  phone       String?
  wechat      String?
  company     String?
  position    String?
  source      String?
  level       String?
  status      String    @default("potential")
  remark      String?
  tags        String?
  lastFollowUpAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  followUps   CrmFollowUp[]
  reminders   CrmReminder[]
}

model CrmFollowUp {
  id              String    @id @default(uuid())
  customerId      String
  customer        CrmCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type            String
  content         String
  nextPlan        String?
  nextFollowUpAt  DateTime?
  createdBy       String
  createdAt       DateTime  @default(now())
}

model CrmTag {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  color       String    @default("#1890ff")
  createdAt   DateTime  @default(now())
  
  @@unique([userId, name])
}

model CrmAutomationRule {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  trigger     String
  condition   String
  action      String
  isActive    Boolean   @default(true)
  lastRunAt   DateTime?
  runCount    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model CrmReminder {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customerId  String
  customer    CrmCustomer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  type        String
  title       String
  remindAt    DateTime
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now())
  
  @@index([userId, remindAt])
}

// ============================================
// 通知、设置、企业信息
// ============================================

model Notification {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  title       String
  content     String
  isRead      Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

model CompanyInfo {
  id          String    @id @default(uuid())
  userId      String    @unique
  name        String    @default("上海百智集网络科技有限公司")
  logo        String?
  industry    String?
  size        String?
  address     String?
  description String?
  contact     String?
  phone       String?
  email       String?
  website     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Setting {
  id          String    @id @default(uuid())
  userId      String
  key         String
  value       String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([userId, key])
}

// ============================================
// 功能开关系统
// ============================================

model FeatureSwitch {
  id          String    @id @default(uuid())
  code        String    @unique
  name        String
  description String?
  icon        String?
  enabled     Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  subFeatures FeatureSubSwitch[]
}

model FeatureSubSwitch {
  id          String    @id @default(uuid())
  featureCode String
  code        String
  name        String
  description String?
  enabled     Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  feature     FeatureSwitch @relation(fields: [featureCode], references: [code])
  
  @@unique([featureCode, code])
}

model UserFeatureSwitch {
  id          String    @id @default(uuid())
  userId      String
  featureCode String
  enabled     Boolean
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([userId, featureCode])
}

// ============================================
// 代理商系统
// ============================================

model Agent {
  id            String    @id @default(uuid())
  userId        String    @unique
  name          String
  level         String    @default("district")
  region        String?
  agentType     String    @default("commission")
  commissionRate Decimal  @default(0.3) @db.Decimal(10,2)
  oneTimeFee    Decimal   @default(0) @db.Decimal(10,2)
  totalPaid     Decimal   @default(0) @db.Decimal(10,2)
  monthlyPaid   Decimal   @default(0) @db.Decimal(10,2)
  lastPaidAt    DateTime?
  status        String    @default("active")
  balance       Decimal   @default(0) @db.Decimal(10,2)
  totalRevenue  Decimal   @default(0) @db.Decimal(10,2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  user          User      @relation(fields: [userId], references: [id])
  parentId      String?
  parent        Agent?    @relation("AgentHierarchy", fields: [parentId], references: [id])
  children      Agent[]   @relation("AgentHierarchy")
  agentRelations UserAgentRelation[]
  payments      Payment[]
  settlements   Settlement[]
}

model UserAgentRelation {
  id          String    @id @default(uuid())
  userId      String
  agentId     String
  createdAt   DateTime  @default(now())
  
  user        User      @relation(fields: [userId], references: [id])
  agent       Agent     @relation(fields: [agentId], references: [id])
  
  @@unique([userId])
}

model AgentStats {
  id          String    @id @default(uuid())
  agentId     String
  period      String
  periodStart DateTime
  periodEnd   DateTime
  newCustomers Int     @default(0)
  activeCustomers Int  @default(0)
  totalRevenue Decimal  @default(0) @db.Decimal(10,2)
  commission  Decimal   @default(0) @db.Decimal(10,2)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@unique([agentId, period, periodStart])
}

// ============================================
// 贴牌配置
// ============================================

model BrandingConfig {
  id          String    @id @default(uuid())
  userId      String    @unique
  appName     String    @default("智枢AI")
