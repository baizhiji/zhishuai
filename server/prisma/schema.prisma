// ============================================
// 工单系统
// ============================================

model Ticket {
  id            String    @id @default(uuid())
  ticketNo      String    @unique
  userId        String?
  agentId       String?
  category      String?   // 客服分类（如 billing/technical/general）
  type          String    @default("feature")  // feature | quota | tech
  priority      String    @default("medium")   // low | medium | high | normal
  title         String
  content       String?   // 客服工单详细内容
  description   String?   // 申请工单描述
  attachments   Json?
  status        String    @default("pending")  // pending | approved | rejected | closed
  assigneeId    String?
  assigneeName  String?
  rejectReason  String?
  closedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  responses     TicketResponse[]

  @@index([userId, createdAt])
  @@index([agentId, status])
  @@index([status, createdAt])
}

model TicketResponse {
  id            String    @id @default(uuid())
  ticketId      String
  userId        String?
  userName      String?
  userRole      String?
  action        String?   // approve | reject | comment
  content       String?
  attachments   Json?
  isInternal    Boolean   @default(false)
  operatorId    String?
  operatorRole  String?   // admin | agent
  createdAt     DateTime  @default(now())
  
  ticket        Ticket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  
  @@index([ticketId, createdAt])
}

