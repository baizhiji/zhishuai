# 数据库配置 (腾讯云TDSQL-C MySQL)
DATABASE_URL="mysql://user:password@host:port/zhishuai?connection_limit=20&pool_timeout=10"

# JWT配置（生产环境必须使用强随机密钥！）
JWT_SECRET="your-strong-random-secret-here"
JWT_EXPIRES_IN="7d"

# 服务配置
PORT=3001
NODE_ENV=production

# API配置
API_VERSION="v1"

# 前端URL（用于CORS和回调）
FRONTEND_URL="https://yourdomain.com"
APP_URL="https://app.yourdomain.com"

# AI 服务 - 阿里云百炼（编程助手等）
DASHSCOPE_API_KEY=""

# AI 服务 - 腾讯云 TokenHub（编程助手等）
TENCENT_TOKENHUB_API_KEY=""

# AI 服务 - OpenAI（可选）
OPENAI_API_KEY=""

# ============ 推送通知配置 ============

# FCM (Firebase Cloud Messaging) - 使用 HTTP v1 API + OAuth2
# 方式1: 指向service account JSON文件路径（推荐生产环境）
GOOGLE_APPLICATION_CREDENTIALS=""
# 方式2: service account JSON字符串（适合Docker/PM2部署）
GOOGLE_SERVICE_ACCOUNT_JSON=""
# 示例JSON格式:
# {"type":"service_account","project_id":"your-project","private_key_id":"xxx","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"firebase-adminsdk@your-project.iam.gserviceaccount.com","client_id":"xxx","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# APNs (Apple Push Notification service) - 仅在不用FCM统管iOS时需要
# APNs使用JWT证书（.p8格式），需从Apple Developer获取
APNS_KEY_ID=""
APNS_TEAM_ID=""
APNS_PRIVATE_KEY=""

# Web Push (VAPID) - 浏览器推送
# 生成密钥: node -e "console.log(JSON.stringify(require('web-push').generateVAPIDKeys()))"
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@yourdomain.com"

# ============ 其他配置 ============

# Sentry 错误监控（可选）
SENTRY_DSN=""

# 文件上传目录（可选，默认 uploads）
UPLOAD_DIR="uploads"

# 管理员初始化密码（仅 seed 时使用）
ADMIN_SEED_PASSWORD="20061218"
