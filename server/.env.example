# 数据库配置 (腾讯云TDSQL-C MySQL)
DATABASE_URL="mysql://user:password@host:port/zhishuai?connection_limit=20&pool_timeout=10"

# JWT配置（生产环境必须使用强随机密钥！）
JWT_SECRET="your-strong-random-secret-here"
JWT_EXPIRES_IN="7d"

# 服务配置
PORT=3001
NODE_ENV=production

# API配置
API_VERSION="v1"

# 前端URL（用于CORS和回调）
FRONTEND_URL="https://yourdomain.com"
APP_URL="https://app.yourdomain.com"

# AI 服务 - 阿里云百炼（编程助手等）
DASHSCOPE_API_KEY=""

# AI 服务 - 腾讯云 TokenHub（编程助手等）
TENCENT_TOKENHUB_API_KEY=""

# AI 服务 - OpenAI（可选）
OPENAI_API_KEY=""

# Sentry 错误监控（可选）
SENTRY_DSN=""

# 文件上传目录（可选，默认 uploads）
UPLOAD_DIR="uploads"

# 管理员初始化密码（仅 seed 时使用）
ADMIN_SEED_PASSWORD="20061218"
