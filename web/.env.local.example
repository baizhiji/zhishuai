# API配置
NEXT_PUBLIC_API_BASE_URL=https://api.zhishuai.com/v1
NEXT_PUBLIC_APP_URL=https://zhishuai.com

# OSS配置
NEXT_PUBLIC_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
NEXT_PUBLIC_OSS_BUCKET=zhishuai-assets
NEXT_PUBLIC_OSS_REGION=oss-cn-hangzhou

# 第三方服务
NEXT_PUBLIC_ALIYUN_API_KEY=your_aliyun_api_key
NEXT_PUBLIC_VOLCENGINE_API_KEY=your_volcengine_api_key

# 应用配置
NEXT_PUBLIC_APP_NAME=智枢AI
NEXT_PUBLIC_APP_VERSION=1.0.0

# 支付配置
NEXT_PUBLIC_ALIPAY_APP_ID=your_alipay_app_id
NEXT_PUBLIC_WECHAT_APP_ID=your_wechat_app_id

# 统计分析
NEXT_PUBLIC_GA_TRACKING_ID=your_google_analytics_id
NEXT_PUBLIC_BAIDU_ANALYTICS_ID=your_baidu_analytics_id
