# 1. 忽略当前目录下的所有文件和文件夹
/*

# 2. 只追踪配置文件、coze文件、web源代码、apk移动端
!/ecosystem.config.js
!/openclaw.json
!/scripts
!/.coze
!/.gitignore
!/web
!/apk
!/backend
!/server
!/deploy
!/docs
!/shared
!/.github
!/package.json
!/README.md

# 3. web目录下的忽略项
web/.next
web/node_modules
web/.env                    # 敏感配置
web/.env.local              # 本地开发配置（可提交）
web/.env.production          # 生产环境配置（可提交）
web/.turbo
web/dist
web/out
web/.DS_Store
web/*.log
web/.pnpm-debug.log*

# 4. apk目录下的忽略项
apk/.next
apk/node_modules
apk/.env                   # 敏感配置
apk/.env.local             # 本地开发配置（可提交）
apk/.env.production        # 生产环境配置（可提交）
apk/out
apk/dist
apk/.DS_Store
apk/*.log

# 5. backend目录下的忽略项
backend/node_modules
backend/.env*
backend/dist
backend/logs

# 6. shared目录下的忽略项
shared/node_modules
shared/.env*
shared/dist

# 7. server目录下的忽略项
server/node_modules
server/.env*
server/dist
server/logs
server/.pnpm-debug.log*
